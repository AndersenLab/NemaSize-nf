//author: Mike Sauria <mike.sauria@jhu.edu>
import java.time.*
Date now = new Date()

//params.email = "mike.sauria@gmail.com"

profiles {
    standard { includeConfig 'conf/rockfish.config' }
    rockfish { includeConfig 'conf/rockfish.config' }
}

params {
    tracedir = "pipeline_info"
    timestamp = now.format("yyyyMMdd-HH-mm-ss")
    debug = false
    help = false
    slurm_temp = "${projectDir}/assets/NemaSize_slurm_temp.sh"
    data_f = null
    email = null
    batch_size = 20             // validated to fit comfortably inside the 1h
                                // RUN_BATCH wall time (~35 min observed worst case).
                                // Hard-capped at 25 in main.nf.
    clean_batches = true        // wipe <data_f>/batches/ before run (idempotent resumes)
    clean_intermediate = true   // wipe <data_f>/batches/ after successful merge
    force_merge = false
}

timeline {
    enabled = true
    file = "${params.tracedir}/${params.timestamp}_timeline.html"
}
report {
    enabled = true
    file = "${params.tracedir}/${params.timestamp}_report.html"
}
trace {
    enabled = true
    file = "${params.tracedir}/${params.timestamp}_trace.txt"
}
dag {
    enabled = true
    file = "${params.tracedir}/${params.timestamp}_dag.svg"
}