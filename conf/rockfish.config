// Rockfish CPU profile.
//
//   - SLURM executor for compute-heavy processes (RUN_BATCH).
//   - Local executor for light bookkeeping (DISCOVER_IMAGES, MAKE_BATCH_DIR);
//     these are tiny and SLURM submission overhead would dominate.
//   - Singularity is enabled cluster-wide. Image lookup honors the lab's
//     shared cache via NXF_SINGULARITY_CACHEDIR (already set in user envs to
//     /vast/eande106/singularity/).

singularity {
    enabled    = true
    autoMounts = true
}

executor {
    name      = 'slurm'
    queueSize = 250   // concurrent submitted+running RUN_BATCH jobs; safe
                      // headroom (~3% of partition cores) and keeps the
                      // login-node Nextflow process responsive. Raise if you
                      // confirm SLURM and login-node load are happy.
}

process {
    // Default: short local task (used by DISCOVER_IMAGES, MAKE_BATCH_DIR).
    executor = 'local'

    withName: RUN_BATCH {
        executor = 'slurm'
        queue    = 'parallel'
        cpus     = 4
        memory   = 16.GB
        time     = '1h'
    }

    // Merge is mostly small-file I/O; submit to SLURM so login-node load
    // stays light on big runs (thousands of contour txts to copy).
    withName: MERGE_RESULTS {
        executor = 'slurm'
        queue    = 'parallel'
        cpus     = 1
        memory   = 8.GB
        time     = '30m'
    }
}